# ═══════════════════════════════════════════════════════════════════════════
# NEXUS — Environment Configuration
# Copy to .env and fill in your own values. Everything is NEXUS_* prefixed
# to avoid collisions with unrelated tools running on your machine.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Kafka ────────────────────────────────────────────────────────────────
NEXUS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Neo4j ────────────────────────────────────────────────────────────────
NEXUS_NEO4J_URI=bolt://localhost:7687
NEXUS_NEO4J_USERNAME=neo4j
NEXUS_NEO4J_PASSWORD=nexus_password

# ─── ChromaDB ─────────────────────────────────────────────────────────────
NEXUS_CHROMA_HOST=localhost
NEXUS_CHROMA_PORT=8100

# ─── Redis ────────────────────────────────────────────────────────────────
NEXUS_REDIS_HOST=localhost
NEXUS_REDIS_PORT=6380

# ─── LLM ─────────────────────────────────────────────────────────────────
# Leave the key blank to run in mock mode (no network calls).
# For real LLM access use any LiteLLM-supported provider, e.g.
#   openai/gpt-4o-mini, anthropic/claude-3-5-sonnet, openrouter/<model>
NEXUS_LLM_MODEL=openrouter/qwen/qwen3-235b-a22b
NEXUS_LLM_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────────────────
NEXUS_MODEL_NAME=all-MiniLM-L6-v2
NEXUS_EMBEDDING_DIM=384

# ─── Reverse proxy ───────────────────────────────────────────────────────
# On a VPS, set NEXUS_DOMAIN=example.com and point *.example.com at the host.
# Locally this is unused — Caddy serves *.localhost.
NEXUS_DOMAIN=localhost

# ─── Frontend ────────────────────────────────────────────────────────────
# Leave blank in production; the frontend auto-detects gateway.<domain>.
VITE_API_URL=
