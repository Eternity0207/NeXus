# ═══════════════════════════════════════════════════════════════════════════
# NEXUS Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Kafka ────────────────────────────────────────────────────────────────
NEXUS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Neo4j ────────────────────────────────────────────────────────────────
NEXUS_NEO4J_URI=bolt://localhost:7687
NEXUS_NEO4J_USERNAME=neo4j
NEXUS_NEO4J_PASSWORD=nexus_password

# ─── ChromaDB ─────────────────────────────────────────────────────────────
NEXUS_CHROMA_HOST=localhost
NEXUS_CHROMA_PORT=8100

# ─── Redis ────────────────────────────────────────────────────────────────
NEXUS_REDIS_HOST=localhost
NEXUS_REDIS_PORT=6380

# ─── LLM Configuration ───────────────────────────────────────────────────
# Set your OpenAI / Anthropic API key for real LLM responses.
# Leave empty to use mock responses (development mode).
NEXUS_LLM_MODEL=gpt-3.5-turbo
NEXUS_LLM_API_KEY=

# ─── Embedding Model ─────────────────────────────────────────────────────
NEXUS_MODEL_NAME=all-MiniLM-L6-v2
NEXUS_EMBEDDING_DIM=384

# ─── Frontend ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
